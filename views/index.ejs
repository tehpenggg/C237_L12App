<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Study Planner</title>
</head>

<body>
    <!--gets navbar from partials/header.ejs and inserts it here -->
    <%- include('partials/navbar.ejs') %>

        <div class="container mt-4">
            <h1 class="mb-4">Today's Session</h1>

            <table class="table table-bordered table-hover shadow">

                <tr>
                    <th>Session Name</th>
                    <th>Duration</th>
                    <th>Session Type</th>
                    <th>Actions</th>
                </tr>

                <% for(let i=0; i < sessions.length; i++) { %>
                    <tr>

                        <td>
                            <%= sessions[i].sessionName %> <br>
                        </td>
                        
                        <td>
                            <%= sessions[i].sessionDuration %> mins
                        </td>

                        <td>
                            <%= sessions[i].sessionType %>
                        </td>

                        <td>

                            <form action="/delete/<%= sessions[i].id %>" method="POST" style="display:inline;">

                                <button class="btn btn-danger btn-sm">
                                    Delete
                                </button>

                            </form>

                        </td>
                    </tr>
                <% } %>
                

            </table>
            
        </div>
</body>

</html>